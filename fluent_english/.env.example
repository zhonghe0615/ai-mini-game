# Copy to .env and fill in your keys.

# 聊天模型（二选一或都设）：仅设 OPENAI 则用 OpenAI 聊天；用 DeepSeek 等可只设 CHAT_*
OPENAI_API_KEY=sk-your-openai-key-here
# CHAT_API_KEY=sk-your-key-here
# CHAT_BASE_URL=https://api.deepseek.com
# CHAT_MODEL=deepseek-chat

# 向量检索（可选，默认用上面聊天同源）：换 embedding 源时单独设
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small

# 语音（TTS、Whisper、gpt-audio 听音反馈）目前仅支持 OpenAI，需 OPENAI_API_KEY。
# 口音纠音（听音）由浏览器内 ffmpeg.wasm 将录音转为 WAV，服务端无需安装 ffmpeg。
